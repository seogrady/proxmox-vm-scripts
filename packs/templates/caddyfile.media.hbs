:80 {
  encode gzip

  handle_path /healthz {
    respond "ok" 200
  }

  {{#each features.media_services.ui_routes}}
  {{#unless (eq this.path "/")}}
  handle {{this.path}}* {
    redir http://{host}:{{this.port}}/ 308
  }
  {{/unless}}
  {{/each}}

  handle / {
    root * /srv/ui-index
    file_server
  }
}
