#!/usr/bin/env bash
set -euo pipefail

VMCTL_TAILSCALE_ENABLED={{#if tailscale.enabled}}1{{else}}0{{/if}}
if [[ "$VMCTL_TAILSCALE_ENABLED" != "1" ]]; then
  echo "tailscale disabled for this resource"
  exit 0
fi

VMCTL_TAILSCALE_AUTH_KEY="{{tailscale.auth_key}}"
VMCTL_TAILSCALE_HOSTNAME="{{tailscale.hostname}}"
VMCTL_TAILSCALE_ROUTES="{{tailscale.advertise_routes}}"
VMCTL_TAILSCALE_TAGS="{{tailscale.tags}}"
VMCTL_TAILSCALE_ACCEPT_ROUTES={{#if tailscale.accept_routes}}1{{else}}0{{/if}}
VMCTL_TAILSCALE_EXIT_NODE={{#if tailscale.advertise_exit_node}}1{{else}}0{{/if}}

already_authenticated=0
if command -v tailscale >/dev/null 2>&1 && tailscale status --json >/tmp/vmctl-tailscale-status.json 2>/dev/null; then
  already_authenticated="$(python3 - <<'PY'
import json
try:
    with open("/tmp/vmctl-tailscale-status.json", encoding="utf-8") as handle:
        status = json.load(handle)
    print(1 if status.get("HaveNodeKey") and status.get("BackendState") in {"Running", "Starting"} else 0)
except Exception:
    print(0)
PY
)"
fi

if [[ "$already_authenticated" == "1" ]]; then
  set_args=()
{{#if tailscale.hostname}}
  set_args+=(--hostname "$VMCTL_TAILSCALE_HOSTNAME")
{{/if}}
{{#if tailscale.advertise_routes}}
  set_args+=(--advertise-routes "$VMCTL_TAILSCALE_ROUTES")
{{/if}}
{{#if tailscale.advertise_exit_node}}
  set_args+=(--advertise-exit-node)
{{/if}}
{{#if tailscale.accept_routes}}
  set_args+=(--accept-routes)
{{/if}}
  if ((${#set_args[@]} > 0)); then
    tailscale set "${set_args[@]}"
  fi
  exit 0
fi

if [[ -z "$VMCTL_TAILSCALE_AUTH_KEY" ]]; then
  echo "tailscale is not authenticated and no auth key is configured"
  exit 1
fi

args=(--reset --auth-key "$VMCTL_TAILSCALE_AUTH_KEY")
{{#if tailscale.hostname}}
args+=(--hostname "$VMCTL_TAILSCALE_HOSTNAME")
{{/if}}
{{#if tailscale.advertise_routes}}
args+=(--advertise-routes "$VMCTL_TAILSCALE_ROUTES")
{{/if}}
{{#if tailscale.advertise_exit_node}}
args+=(--advertise-exit-node)
{{/if}}
{{#if tailscale.accept_routes}}
args+=(--accept-routes)
{{/if}}
{{#if tailscale.tags}}
args+=(--advertise-tags "$VMCTL_TAILSCALE_TAGS")
{{/if}}

{{#if tailscale.advertise_routes}}
cat >/etc/sysctl.d/99-tailscale-forwarding.conf <<'EOF'
net.ipv4.ip_forward = 1
net.ipv6.conf.all.forwarding = 1
EOF
sysctl -w net.ipv4.ip_forward=1
sysctl -w net.ipv6.conf.all.forwarding=1
{{/if}}
{{#if tailscale.advertise_exit_node}}
cat >/etc/sysctl.d/99-tailscale-forwarding.conf <<'EOF'
net.ipv4.ip_forward = 1
net.ipv6.conf.all.forwarding = 1
EOF
sysctl -w net.ipv4.ip_forward=1
sysctl -w net.ipv6.conf.all.forwarding=1
{{/if}}

tailscale up "${args[@]}"
