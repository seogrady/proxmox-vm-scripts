GITEA_RUNNER_ENABLED={{features.gitea_runner.enabled}}
GITEA_RUNNER_ACT_VERSION={{features.gitea_runner.act_version}}
GITEA_RUNNER_REGISTRATION_RETRIES={{features.gitea_runner.registration_retries}}
GITEA_RUNNER_REGISTRATION_RETRY_DELAY_SECONDS={{features.gitea_runner.registration_retry_delay_seconds}}
{{#each features.gitea_runner.instances}}
GITEA_RUNNER_INSTANCE_NAME_{{@index}}={{name}}
GITEA_RUNNER_INSTANCE_BASE_URL_{{@index}}={{base_url}}
GITEA_RUNNER_INSTANCE_SCOPE_{{@index}}={{scope}}
GITEA_RUNNER_INSTANCE_REPO_{{@index}}={{repo}}
GITEA_RUNNER_INSTANCE_ORG_{{@index}}={{org}}
GITEA_RUNNER_INSTANCE_RUNNER_NAME_{{@index}}={{runner_name}}
GITEA_RUNNER_INSTANCE_LABELS_{{@index}}={{runner_labels}}
GITEA_RUNNER_INSTANCE_CAPACITY_{{@index}}={{runner_capacity}}
GITEA_RUNNER_INSTANCE_ADMIN_USER_{{@index}}={{admin_user}}
GITEA_RUNNER_INSTANCE_ADMIN_PASSWORD_{{@index}}={{admin_password}}
GITEA_RUNNER_INSTANCE_EPHEMERAL_{{@index}}={{ephemeral}}
{{/each}}
VMCTL_RESOURCE_NAME={{resource.name}}
VMCTL_HOST_SHORT={{resource.name}}
