{
  "resource": {
    "terraform_data": {
      "this": {
        "input": {
          "bridge": "${var.bridge}",
          "kind": "vm",
          "name": "${var.resource.name}",
          "node_name": "${var.node_name}",
          "resource": "${var.resource}",
          "storage": "${var.storage}",
          "template": "${var.template}",
          "vmid": "${try(var.resource.vmid, null)}"
        }
      }
    }
  },
  "terraform": {
    "required_providers": {
      "proxmox": {
        "source": "bpg/proxmox",
        "version": ">= 0.70.0, < 0.98.1"
      }
    }
  }
}