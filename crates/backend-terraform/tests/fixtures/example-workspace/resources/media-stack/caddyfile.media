:80 {
  encode gzip

  handle_path /healthz {
    respond "ok" 200
  }

  handle /jellyfin* {
    reverse_proxy jellyfin:8096
  }
  handle /sonarr* {
    reverse_proxy sonarr:8989
  }
  handle /radarr* {
    reverse_proxy radarr:7878
  }
  handle /prowlarr* {
    reverse_proxy prowlarr:9696
  }
  handle /qbittorrent* {
    reverse_proxy gluetun:8080
  }

  handle / {
    root * /srv/ui-index
    file_server
  }
}
